// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Auctioneer{
  id    String @default(uuid()) @id
  email String[] 
  name  String
  phones String[]
  url   String[]
  division String[]
}

enum Vehicle {
  Car
  Motorcycle
  Default
}

model AuctionRound {
  id        String   @id @default(uuid())
  date      DateTime
  value     String

  auction   Auction  @relation(fields: [auctionId], references: [id])
  auctionId String
}

model Legal {
  id         String   @id @default(uuid())
  caseNumber String
  plaintiff  String
  defendant  String

  auction    Auction  @relation(fields: [auctionId], references: [id])
  auctionId  String   @unique
}


model Auction {
  id            String   @id @default(uuid())
  url           String
  title         String
  city          String
  state         String
  seller        String
  auctioneer    String
  initialValue  Float
  openDate      DateTime
  closeDate     DateTime
  lastBid       Float
  category      AuctionCategory  

  rounds        AuctionRound[]
  legal         Legal?
  vehicleDetail VehicleDetail?   
  propertyDetail PropertyDetail? 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum AuctionCategory {
  Car
  Motorcycle
  Apartment
  House
  Land
  CommercialProperty
  Default
}

model VehicleDetail {
  id                String   @id @default(uuid())
  
  brand             String?  
  model             String?  
  yearManufacture   String?  
  yearModel         String?  
  uf                String?  
  plate             String?  
  chassis           String?  
  renavam           String?  
  engineNumber      String?  
  
  mileage           String?  
  fuel              String?  
  color             String?  
  transmission      String?  
  doors             Int?     
  armored           Boolean? 
  
  engine            String?  
  gearbox           String?  
  steering          String?  
  paint             String?  
  bodywork          String?  
  upholstery        String?  
  tires             String?  
  electrical        String?  
  mechanics         String?  

  conservationState String?  
  working           Boolean? 

  accessories       Json?    

  description       String?

  inspectionAddress String?  

  auction           Auction  @relation(fields: [auctionId], references: [id])
  auctionId         String   @unique
}

model PropertyDetail {
  id                String   @id @default(uuid())
  type              String?  
  area              String?  
  privatArea        String?  
  landArea          String?  
  bedrooms          Int?
  bathrooms         Int?
  parkingSpots      Int?
  floor             String?  
  registry          String?  
  registration      String?  
  conservationState String?
  occupied          Boolean? 
  description       String?
  amenities         String[] 

  auction           Auction  @relation(fields: [auctionId], references: [id])
  auctionId         String   @unique
}
